{
  "name": "@primis/root",
  "version": "0.0.1",
  "private": true,
  "description": "Primis — health data aggregation, deterministic scoring, and AI-native coaching platform",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "echo \"not implemented — configure per-package in later phases\""
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react-dom",
        "react-native-worklets"
      ]
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@primis/core-types": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^1"
  }
}
