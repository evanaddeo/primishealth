# ============================================================
# Primis Environment Variables — EXAMPLE FILE
# Copy to .env for local development. Never commit .env.
# Real credentials are never stored here — placeholders only.
# ============================================================

# --- App (public / mobile-safe) ---
# Safe to include in client-side bundles; no secrets below this line.
NODE_ENV=development
APP_ENV=local

# --- Mobile API (Expo public — inlined into the app bundle by Metro at build time) ---
# EXPO_PUBLIC_* variables are NOT secrets; never put credentials here.
# Set EXPO_PUBLIC_API_BASE_URL to the real API gateway URL in staging/production builds.
# Set EXPO_PUBLIC_MOCK_MODE=false in staging/production to enable real network calls.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_MOCK_MODE=true

# --- Backend API (server-side only) ---
DATABASE_URL=postgres://primis:primis@localhost:5432/primis_dev
DATABASE_SSL=false

# --- Auth — AWS Cognito (placeholder; real values are Phase Z) ---
COGNITO_USER_POOL_ID=PLACEHOLDER
COGNITO_CLIENT_ID=PLACEHOLDER
COGNITO_REGION=us-east-1

# --- Provider OAuth (placeholder; real values are Phase Z) ---
# MUST NOT be committed or exposed in mobile builds.
GOOGLE_HEALTH_CLIENT_ID=PLACEHOLDER
GOOGLE_HEALTH_CLIENT_SECRET=PLACEHOLDER

# --- AI Gateway (placeholder; real keys are Phase Z) ---
# MUST NOT be committed or exposed in mobile builds.
OPENAI_API_KEY=PLACEHOLDER
ANTHROPIC_API_KEY=PLACEHOLDER

# --- AWS (never commit real values; use OIDC in CI) ---
AWS_REGION=us-east-1
